{
  "name": "novelforge",
  "version": "1.0.0",
  "description": "AI辅助长篇网文创作工作台",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "tsx watch src/index.ts",
    "dev:frontend": "cd studio && pnpm dev",
    "build": "tsc && cd studio && pnpm build",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "init": "tsx scripts/init.ts",
    "knowledge:process": "tsx tools/data-processor.ts",
    "fine-tune:prepare": "tsx tools/fine-tune-generator.ts",
    "fine-tune:train": "bash scripts/fine-tune.sh",
    "setup": "pnpm run init && pnpm install"
  },
  "keywords": [
    "novel",
    "writing",
    "ai",
    "webnovel"
  ],
  "author": "NovelForge Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liuyunak/NovelForge.git"
  },
  "bugs": {
    "url": "https://github.com/liuyunak/NovelForge/issues"
  },
  "homepage": "https://github.com/liuyunak/NovelForge#readme",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.11.0",
    "dotenv": "^16.4.0",
    "hono": "^4.4.0",
    "node-cache": "^5.1.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sql.js": "^1.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/node": "^20.14.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.8"
  }
}
