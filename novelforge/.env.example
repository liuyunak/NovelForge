# ===================================================
# NovelForge v3.5 — AI 辅助长篇网文创作工作台
# ===================================================
# 首次运行时会启动 Web 配置向导，无需手动编辑本文件。
# 如需手动配置，请复制本文件为 .env 并修改以下配置。
# ===================================================

# ==================== AI 供应商 ====================
# 通过 Web 界面配置（推荐）：
#   启动服务后访问 http://localhost:3000
#   进入 设置 → AI 供应商 → 添加供应商
#
# 如果您想手动配置，可在此填入默认供应商信息：
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==================== 服务配置 ====================
PORT=3001
# ⚠️ SECURITY: HOST=0.0.0.0 binds to ALL network interfaces, making the API
# accessible from any device on the network (and the internet, if no firewall).
# For local-only development, use HOST=127.0.0.1 instead.
# For production, set HOST=0.0.0.0 AND configure CORS_ORIGINS + a reverse proxy.
HOST=0.0.0.0
VITE_PORT=3000

# ==================== 安全 ====================
# 生产环境请务必设置为随机强密码！
# Linux/macOS: openssl rand -hex 32
# Windows PowerShell: -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | % {[char]$_})
JWT_SECRET=

# ==================== 数据库 ====================
DB_PATH=./data/novelforge.db

# ==================== 日志 ====================
LOG_LEVEL=info

# ==================== 功能开关 ====================
FEATURE_COVER_GENERATION=false
FEATURE_SCRIPT_EXPORT=true
FEATURE_AI_DETECTION=false
FEATURE_STYLE_TRANSFER=true

# ==================== CORS（可选） ====================
# ⚠️ SECURITY: When HOST=0.0.0.0, the server listens on all interfaces.
# Without CORS_ORIGINS set, the default allows all local origins.
# For production deployment, ALWAYS restrict CORS_ORIGINS to your actual
# frontend domain(s) and place a reverse proxy (nginx/caddy) in front.
# Example: CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com
